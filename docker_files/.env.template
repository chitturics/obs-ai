# Chainlit Splunk Assistant - Environment Variables
#
# Copy this file to .env and fill in the values.
# The start_all.sh script will automatically load variables from .env if it exists.

# ============================================================================
# PostgreSQL Database Configuration
# ============================================================================
POSTGRES_USER=chainlit
POSTGRES_PASSWORD=chainlit
POSTGRES_DB=chainlit
POSTGRES_PORT=5432

# ============================================================================
# ChromaDB Vector Store Configuration
# ============================================================================
CHROMA_PORT=8001

# ============================================================================
# Search Optimizer Service Configuration
# ============================================================================
SEARCH_OPT_PORT=9005

# ============================================================================
# Ollama LLM Service Configuration
# ============================================================================
OLLAMA_PORT=11430

# ============================================================================
# Chainlit UI Application Configuration
# ============================================================================
CHAINLIT_PORT=8000
# Set to 'true' to enable login screen, 'false' for anonymous access
ENABLE_AUTHENTICATION=false


# ============================================================================
# Admin User (if authentication is enabled)
# ============================================================================
ADMIN_USER=admin
ADMIN_PASSWORD=admin


# ============================================================================
# Application Secrets
#
# It is strongly recommended to change these default values for production.
# Use 'openssl rand -hex 32' to generate secure random secrets.
# ============================================================================
# Secret for signing authentication tokens (used by Chainlit).
CHAINLIT_AUTH_SECRET=change_this_to_a_real_secret_string
# Secret for signing JWTs (if used by a custom auth backend).
JWT_SECRET=change_this_to_another_super_secret_string


# ============================================================================
# Third-Party Integrations (Optional)
# ============================================================================
# Credentials for SharePoint ingestion via Azure AD
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=

# Personal Access Token (PAT) for GitHub repository ingestion
GITHUB_TOKEN=


# ============================================================================
# Splunk Validator (Optional)
#
# These are for the optional Splunk Enterprise container used for validation.
# ============================================================================
# The password for the 'admin' user in the Splunk container.
SPLUNK_ADMIN_PASSWORD=ValidatorP@ss123
# The Splunk management port.
SPLUNK_MGMT_PORT=8089
# The Splunk web UI port (avoid conflict with Chainlit UI on 8000).
SPLUNK_WEB_PORT=8005


# ============================================================================
# Monitoring Services (Optional)
# ============================================================================
# The default admin password for the Grafana container.
# Change this for any production or publicly-facing deployment.
GF_SECURITY_ADMIN_PASSWORD=admin


# ============================================================================
# Active Profile
#
# Controls the LLM and embedding models to use.
# Options: LLM_LITE (default), LLM_FAST, LLM_FULL
# ============================================================================
ACTIVE_PROFILE=LLM_LITE
