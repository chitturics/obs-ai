# Obs AI — Environment Configuration
# Copy to .env and fill in ALL required values before running docker-compose.
# Generate secrets: openssl rand -hex 32

# ── Database (REQUIRED) ──
POSTGRES_USER=obsai
POSTGRES_PASSWORD=           # REQUIRED: use a strong password
POSTGRES_DB=chainlit

# ── Authentication (REQUIRED) ──
CHAINLIT_AUTH_SECRET=        # REQUIRED: openssl rand -hex 32
JWT_SECRET=                  # REQUIRED: openssl rand -hex 32
ADMIN_USER=admin
ADMIN_PASSWORD=              # REQUIRED: strong password (min 8 chars, upper+lower+digit)
ENABLE_AUTHENTICATION=true

# ── Grafana (REQUIRED) ──
GF_SECURITY_ADMIN_PASSWORD=  # REQUIRED: strong password

# ── MFA ──
MFA_POLICY=admin_required    # disabled, optional, admin_required, all_required

# ── Networking ──
GATEWAY_PORT=8000
DEPLOYMENT_ENV=production    # development, staging, production

# ── Splunk (optional) ──
SPLUNK_HOST=
SPLUNK_ADMIN_PASSWORD=
SPLUNK_HEC_TOKEN=
SPLUNK_READ_TOKEN=
SPLUNK_WRITE_TOKEN=

# ── Redis (optional) ──
REDIS_PASSWORD=

# ── SCIM Provisioning (optional) ──
SCIM_BEARER_TOKEN=           # Set to enable SCIM user provisioning

# ── Service-to-Service (optional) ──
SERVICE_API_KEY=             # Internal service auth key

# ── LLM Provider (default: ollama) ──
# Set LLM_PROVIDER to switch: ollama, openai, anthropic, google, azure_openai,
#                              openai_compatible, mcp_llm
LLM_PROVIDER=ollama

# Ollama (local — default, no API key needed)
OLLAMA_BASE_URL=http://127.0.0.1:11430

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=              # custom endpoint (optional)

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google Gemini
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-06-01

# OpenAI-compatible (vLLM, LMStudio, LocalAI, etc.)
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=

# MCP-as-LLM (route inference through an MCP server)
MCP_LLM_ENDPOINT=
MCP_LLM_TOOL_NAME=generate
MCP_LLM_API_KEY=

# ── Container Management ──
DOCKER_SOCKET_PATH=/var/run/docker.sock
